# ── Alpaca ────────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_MODE=paper

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=postgresql://autotrader:yourpassword@localhost:5432/autotrader
# AWS Lightsail (replace with your RDS endpoint):
# DATABASE_URL=postgresql://autotrader:yourpassword@your-rds-endpoint:5432/autotrader

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Email Alerts (SendGrid) ───────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-key-here
ALERT_FROM_EMAIL=alerts@yourdomain.com

# ── Trading Config ────────────────────────────────────────────────────────────
CAPITAL=5000
DAILY_TARGET_MIN=100
DAILY_TARGET_MAX=250
MAX_DAILY_LOSS=150

# ── Security ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
